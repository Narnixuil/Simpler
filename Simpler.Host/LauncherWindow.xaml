<Window x:Class="Simpler.Host.LauncherWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="#CC1E1E1E"
    Width="660"
    SizeToContent="Height"
    MaxHeight="520"
    WindowStartupLocation="CenterScreen"
    Topmost="True"
    KeyDown="Window_KeyDown">
    <DockPanel>
        <!-- Search box -->
        <Grid DockPanel.Dock="Top" Margin="12,12,12,8" Height="36">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox"
                Grid.Column="0"
                Margin="0,0,8,0"
                Height="36"
                FontSize="14"
                Background="#2D2D2D" Foreground="White"
                BorderBrush="#555" CaretBrush="White"
                TextChanged="SearchBox_TextChanged"/>
            <Button x:Name="OpenScriptsButton"
                Grid.Column="1"
                Height="36"
                Padding="0" Width="36"
                Content="📂" ToolTip="Open Scripts"
                Click="OpenScriptsButton_Click"/>
        </Grid>
        <!-- Status bar -->
        <Label x:Name="StatusLabel"
            DockPanel.Dock="Bottom"
            Height="24" FontSize="11"
            Foreground="#888"
            Background="Transparent"
            Margin="12,0"/>
        <!-- Cards -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <WrapPanel x:Name="CardsPanel"
                Orientation="Horizontal"
                Margin="8,0,8,8"/>
        </ScrollViewer>
    </DockPanel>
</Window>


