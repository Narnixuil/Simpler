{
    "icon": "📝",
    "description": "OCR from clipboard image using WeChat OCR",
    "name": "Screenshot OCR (WeChat)",
    "steps": [
        {
            "codeLines": [
                "using System;",
                "using System.IO;",
                "using System.Linq;",
                "using System.Text;",
                "using System.Text.Json;",
                "using System.Diagnostics;",
                "using System.Drawing;",
                "using System.Drawing.Imaging;",
                "using System.Collections.Generic;",
                "using System.Runtime.InteropServices;",
                "using System.Windows.Forms;",
                "using Simpler.Core.Models;",
                "using Simpler.Core.Context;",
                "",
                "async System.Threading.Tasks.Task Run(ScriptContext context)",
                "{",
                "    string imagePath = GetImagePath(context);",
                "    if (string.IsNullOrWhiteSpace(imagePath))",
                "    {",
                "        context.Notify(\"No image found.\");",
                "        return;",
                "    }",
                "",
                "    string wechatDir = FindWeChatDir();",
                "    if (string.IsNullOrWhiteSpace(wechatDir))",
                "    {",
                "        context.Notify(\"WeChat install not found.\");",
                "        return;",
                "    }",
                "",
                "    string ocrBin = FindWeChatOcrBinary();",
                "    if (string.IsNullOrWhiteSpace(ocrBin))",
                "    {",
                "        context.Notify(\"WeChat OCR module not found.\");",
                "        return;",
                "    }",
                "",
                "    string wcocrDll = FindWcocrDll();",
                "    if (string.IsNullOrWhiteSpace(wcocrDll))",
                "    {",
                "        context.Notify(\"wcocr.dll not found. Build swigger/wechat-ocr (x64) and copy wcocr.dll to scripts.\");",
                "        return;",
                "    }",
                "",
                "    string wcocrDir = Path.GetDirectoryName(wcocrDll) ?? \"\";",
                "    string ocrDir = Path.GetDirectoryName(ocrBin) ?? \"\";",
                "    string path = Environment.GetEnvironmentVariable(\"PATH\") ?? \"\";",
                "    Environment.SetEnvironmentVariable(\"PATH\", wcocrDir + \";\" + wechatDir + \";\" + ocrDir + \";\" + path);",
                "    SetDllDirectory(wcocrDir);",
                "",
                "    if (!WechatOCR.call_wechat_ocr(ocrBin, wechatDir, imagePath, out var res))",
                "    {",
                "        context.Notify(\"OCR failed.\");",
                "        return;",
                "    }",
                "",
                "    string extracted = TryExtractText(res);",
                "    if (!string.IsNullOrWhiteSpace(extracted))",
                "    {",
                "        StaRunner.Run(() => Clipboard.SetText(extracted.Trim()));",
                "        ShowToast(\"OCR text copied to clipboard.\");",
                "        WechatOCR.stop_ocr();",
                "        return;",
                "    }",
                "",
                "    if (string.IsNullOrWhiteSpace(res))",
                "    {",
                "        string debug = WriteDebugFile(imagePath, wechatDir, ocrBin, wcocrDll, false, res);",
                "        context.Notify(\"OCR returned no text.\\n\" + debug);",
                "        WechatOCR.stop_ocr();",
                "        return;",
                "    }",
                "",
                "    // fallback: output raw result",
                "    StaRunner.Run(() => Clipboard.SetText(res.Trim()));",
                "    ShowToast(\"OCR text copied to clipboard.\");",
                "    WechatOCR.stop_ocr();",
                "    return;",
                "}",
                "",
                "string GetImagePath(ScriptContext context)",
                "{",
                "    var clipPath = TryGetClipboardImagePath();",
                "    if (!string.IsNullOrWhiteSpace(clipPath)) return clipPath;",
                "",
                "    try { Process.Start(new ProcessStartInfo(\"ms-screenclip:\") { UseShellExecute = true }); } catch { }",
                "",
                "    for (int i = 0; i < 60; i++)",
                "    {",
                "        System.Threading.Thread.Sleep(200);",
                "        clipPath = TryGetClipboardImagePath();",
                "        if (!string.IsNullOrWhiteSpace(clipPath)) return clipPath;",
                "    }",
                "",
                "    return \"\";",
                "}",
                "",
                "string TryGetClipboardImagePath()",
                "{",
                "    Image? img = null;",
                "    try { img = StaRunner.Run(() => Clipboard.ContainsImage() ? Clipboard.GetImage() : null); } catch { }",
                "    if (img != null)",
                "    {",
                "        string tempDir = Path.Combine(Path.GetTempPath(), \"Simpler\");",
                "        Directory.CreateDirectory(tempDir);",
                "        string path = Path.Combine(tempDir, \"ocr_\" + DateTime.Now.ToString(\"yyyyMMdd_HHmmss_fff\") + \".png\");",
                "        img.Save(path, ImageFormat.Png);",
                "        return path;",
                "    }",
                "    return \"\";",
                "}",
                "",
                "string WriteDebugFile(string imagePath, string wechatDir, string ocrBin, string wcocrDll, bool success, string res)",
                "{",
                "    try",
                "    {",
                "        string tempDir = Path.Combine(Path.GetTempPath(), \"Simpler\");",
                "        Directory.CreateDirectory(tempDir);",
                "        string path = Path.Combine(tempDir, \"ocr_debug.txt\");",
                "        var sb = new StringBuilder();",
                "        sb.AppendLine(DateTime.Now.ToString(\"yyyy-MM-dd HH:mm:ss\"));",
                "        sb.AppendLine(\"success=\" + success);",
                "        sb.AppendLine(\"image=\" + imagePath);",
                "        sb.AppendLine(\"wechatDir=\" + wechatDir);",
                "        sb.AppendLine(\"ocrBin=\" + ocrBin);",
                "        sb.AppendLine(\"wcocrDll=\" + wcocrDll);",
                "        sb.AppendLine(\"resLen=\" + (res?.Length ?? 0));",
                "        if (!string.IsNullOrWhiteSpace(res))",
                "        {",
                "            string snippet = res.Length > 400 ? res.Substring(0, 400) : res;",
                "            sb.AppendLine(\"resSnippet=\" + snippet);",
                "        }",
                "        File.WriteAllText(path, sb.ToString(), Encoding.UTF8);",
                "        return \"debug=\" + path;",
                "    }",
                "    catch",
                "    {",
                "        return \"\";",
                "    }",
                "}",
                "",
                "string TryExtractText(string res)",
                "{",
                "    if (string.IsNullOrWhiteSpace(res)) return \"\";",
                "    string t = res.TrimStart();",
                "    if (!(t.StartsWith(\"{\") || t.StartsWith(\"[\"))) return \"\";",
                "",
                "    try",
                "    {",
                "        using var doc = System.Text.Json.JsonDocument.Parse(res);",
                "        var sb = new StringBuilder();",
                "        ExtractTextFromElement(doc.RootElement, sb);",
                "        return sb.ToString();",
                "    }",
                "    catch",
                "    {",
                "        return \"\";",
                "    }",
                "}",
                "",
                "void ExtractTextFromElement(System.Text.Json.JsonElement el, StringBuilder sb)",
                "{",
                "    switch (el.ValueKind)",
                "    {",
                "        case System.Text.Json.JsonValueKind.Object:",
                "            foreach (var p in el.EnumerateObject())",
                "            {",
                "                if (p.NameEquals(\"text\"))",
                "                {",
                "                    if (p.Value.ValueKind == System.Text.Json.JsonValueKind.String)",
                "                    {",
                "                        if (sb.Length > 0) sb.AppendLine();",
                "                        sb.Append(p.Value.GetString());",
                "                    }",
                "                }",
                "                ExtractTextFromElement(p.Value, sb);",
                "            }",
                "            break;",
                "        case System.Text.Json.JsonValueKind.Array:",
                "            foreach (var item in el.EnumerateArray())",
                "                ExtractTextFromElement(item, sb);",
                "            break;",
                "        default:",
                "            break;",
                "    }",
                "}",
                "",
                "void ShowToast(string message)",
                "{",
                "    StaRunner.Run(() =>",
                "    {",
                "        var toast = new System.Windows.Forms.Form",
                "        {",
                "            FormBorderStyle = System.Windows.Forms.FormBorderStyle.None,",
                "            StartPosition   = System.Windows.Forms.FormStartPosition.Manual,",
                "            TopMost = true,",
                "            Width = 320,",
                "            Height = 60,",
                "            BackColor = System.Drawing.Color.FromArgb(30, 30, 30),",
                "            ShowInTaskbar = false",
                "        };",
                "        var label = new System.Windows.Forms.Label",
                "        {",
                "            Text = message,",
                "            ForeColor = System.Drawing.Color.White,",
                "            Dock = System.Windows.Forms.DockStyle.Fill,",
                "            TextAlign = System.Drawing.ContentAlignment.MiddleCenter",
                "        };",
                "        toast.Controls.Add(label);",
                "        var screen = System.Windows.Forms.Screen.PrimaryScreen!.WorkingArea;",
                "        toast.Left = screen.Right - toast.Width - 20;",
                "        toast.Top  = screen.Bottom - toast.Height - 20;",
                "        toast.Shown += async (s, e) =>",
                "        {",
                "            await System.Threading.Tasks.Task.Delay(3000);",
                "            toast.Close();",
                "        };",
                "        System.Windows.Forms.Application.Run(toast);",
                "    });",
                "}",
                "",
                "string FindWeChatDir()",
                "{",
                "    // explicit root",
                "    string explicitRoot = @\"C:\\Program Files\\Tencent\\Weixin\";",
                "",
                "    // prefer versioned subfolder under explicit root (WeChat 4.x)",
                "    try",
                "    {",
                "        if (Directory.Exists(explicitRoot))",
                "        {",
                "            var verDir = Directory.EnumerateDirectories(explicitRoot)",
                "                .Select(d => new DirectoryInfo(d))",
                "                .Where(d => File.Exists(Path.Combine(d.FullName, \"WeixinExt.exe\")) ||",
                "                            File.Exists(Path.Combine(d.FullName, \"WeixinUpdate.exe\")) ||",
                "                            File.Exists(Path.Combine(d.FullName, \"crashpad_handler.exe\")))",
                "                .OrderByDescending(d => d.LastWriteTimeUtc)",
                "                .FirstOrDefault();",
                "            if (verDir != null) return verDir.FullName;",
                "        }",
                "    }",
                "    catch { }",
                "",
                "    // fallback: root if Weixin.exe exists",
                "    if (File.Exists(Path.Combine(explicitRoot, \"Weixin.exe\"))) return explicitRoot;",
                "",
                "    var bases = new List<string>",
                "    {",
                "        @\"C:\\Program Files\\Tencent\\Weixin\",",
                "        @\"C:\\Program Files\\Tencent\\WeChat\",",
                "        @\"C:\\Program Files (x86)\\Tencent\\Weixin\",",
                "        @\"C:\\Program Files (x86)\\Tencent\\WeChat\",",
                "        Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.LocalApplicationData), \"Tencent\", \"WeChat\"),",
                "        Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.LocalApplicationData), \"Tencent\", \"Weixin\"),",
                "        Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.ApplicationData), \"Tencent\"),",
                "        @\"C:\\Users\\xinra\\AppData\\Roaming\\Tencent\",",
                "        @\"C:\\Windows\\System32\\DriverStore\\FileRepository\\intcoed.inf_amd64_7051c5912b2504cc\\WoV\\Tencent\"",
                "    };",
                "",
                "    foreach (var baseDir in bases)",
                "    {",
                "        if (!Directory.Exists(baseDir)) continue;",
                "        try",
                "        {",
                "            // prefer versioned subfolder if any",
                "            var verDir = Directory.EnumerateDirectories(baseDir)",
                "                .Select(d => new DirectoryInfo(d))",
                "                .Where(d => File.Exists(Path.Combine(d.FullName, \"WeixinExt.exe\")) ||",
                "                            File.Exists(Path.Combine(d.FullName, \"WeixinUpdate.exe\")) ||",
                "                            File.Exists(Path.Combine(d.FullName, \"crashpad_handler.exe\")))",
                "                .OrderByDescending(d => d.LastWriteTimeUtc)",
                "                .FirstOrDefault();",
                "            if (verDir != null) return verDir.FullName;",
                "",
                "            var exe = Directory.EnumerateFiles(baseDir, \"Weixin.exe\", SearchOption.AllDirectories)",
                "                .OrderByDescending(File.GetLastWriteTimeUtc)",
                "                .FirstOrDefault();",
                "            if (!string.IsNullOrWhiteSpace(exe)) return Path.GetDirectoryName(exe) ?? \"\";",
                "",
                "            exe = Directory.EnumerateFiles(baseDir, \"WeChat.exe\", SearchOption.AllDirectories)",
                "                .OrderByDescending(File.GetLastWriteTimeUtc)",
                "                .FirstOrDefault();",
                "            if (!string.IsNullOrWhiteSpace(exe)) return Path.GetDirectoryName(exe) ?? \"\";",
                "        }",
                "        catch { }",
                "    }",
                "",
                "    return \"\";",
                "}",
                "string FindWeChatOcrBinary()",
                "{",
                "    string env = Environment.GetEnvironmentVariable(\"WXOCR_DLL\");",
                "    if (!string.IsNullOrWhiteSpace(env) && File.Exists(env)) return env;",
                "",
                "    // only use local copy in scripts\\ScreenshotOcr",
                "    string scriptsDir = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, \"scripts\");",
                "    string local = Path.Combine(scriptsDir, \"ScreenshotOcr\", \"wxocr.dll\");",
                "    if (File.Exists(local)) return local;",
                "",
                "    return \"\";",
                "}",
                "string FindWcocrDll()",
                "{",
                "    string env = Environment.GetEnvironmentVariable(\"WCOCR_DLL\");",
                "    if (!string.IsNullOrWhiteSpace(env) && File.Exists(env)) return env;",
                "",
                "    // prefer subfolder under scripts",
                "    string scriptsDir = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, \"scripts\");",
                "    string subDir = Path.Combine(scriptsDir, \"ScreenshotOcr\");",
                "    string dll = Path.Combine(subDir, \"wcocr.dll\");",
                "    if (File.Exists(dll)) return dll;",
                "",
                "    // explicit scripts path",
                "    string explicitPath = @\"D:\\Programs\\Simpler\\scripts\\wcocr.dll\";",
                "    if (File.Exists(explicitPath)) return explicitPath;",
                "",
                "    // look for wcocr.dll next to scripts (host base)",
                "    dll = Path.Combine(scriptsDir, \"wcocr.dll\");",
                "    if (File.Exists(dll)) return dll;",
                "",
                "    // fallback: alongside executable",
                "    try",
                "    {",
                "        string exeDir = Path.GetDirectoryName(System.Diagnostics.Process.GetCurrentProcess().MainModule?.FileName ?? \"\") ?? \"\";",
                "        if (!string.IsNullOrWhiteSpace(exeDir))",
                "        {",
                "            dll = Path.Combine(exeDir, \"wcocr.dll\");",
                "            if (File.Exists(dll)) return dll;",
                "        }",
                "    }",
                "    catch { }",
                "",
                "    return \"\";",
                "}",
                "static class WechatOCR",
                "{",
                "    private delegate void SetResultDelegate(IntPtr result);",
                "",
                "    [DllImport(\"wcocr.dll\", CallingConvention = CallingConvention.Cdecl)]",
                "    private static extern bool wechat_ocr(",
                "        [MarshalAs(UnmanagedType.LPWStr)] string ocr_exe,",
                "        [MarshalAs(UnmanagedType.LPWStr)] string wechat_dir,",
                "        byte[] imgfn,",
                "        SetResultDelegate set_res);",
                "",
                "    [DllImport(\"wcocr.dll\", CallingConvention = CallingConvention.Cdecl)]",
                "    public static extern void stop_ocr();",
                "",
                "    private class StringResult",
                "    {",
                "        private string _result = \"\";",
                "        public void SetResult(IntPtr dt)",
                "        {",
                "            int length = 0;",
                "            while (Marshal.ReadByte(dt, length) != 0) length++;",
                "            byte[] byteArray = new byte[length];",
                "            Marshal.Copy(dt, byteArray, 0, length);",
                "            _result = Encoding.UTF8.GetString(byteArray);",
                "        }",
                "        public string GetResult() => _result;",
                "    }",
                "",
                "    public static bool call_wechat_ocr(string ocr_exe, string wechat_dir, string imgfn, out string res)",
                "    {",
                "        var stringResult = new StringResult();",
                "        var setRes = new SetResultDelegate(stringResult.SetResult);",
                "        bool success = wechat_ocr(ocr_exe, wechat_dir, Encoding.UTF8.GetBytes(imgfn + \"\\0\"), setRes);",
                "        res = stringResult.GetResult();",
                "        return success;",
                "    }",
                "}",
                "",
                "[DllImport(\"kernel32.dll\", SetLastError = true, CharSet = CharSet.Unicode)]",
                "static extern bool SetDllDirectory(string lpPathName);"
            ],
            "op": "csharp"
        }
    ]
}