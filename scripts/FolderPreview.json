{
  "name": "Folder Preview",
  "description": "Preview folder tree in a dialog",
  "icon": "🗂️",
  "steps": [
    {
      "op": "csharp",
      "codeLines": [
        "if (context.SelectedFiles.Count == 0) { context.Notify(\"No selected file or folder.\"); return; }",
        "var target = context.SelectedFiles[0];",
        "var dir = Directory.Exists(target) ? target : (Path.GetDirectoryName(target) ?? \"\");",
        "if (string.IsNullOrWhiteSpace(dir) || !Directory.Exists(dir)) { context.Notify(\"Cannot determine folder path.\"); return; }",
        "",
        "Simpler.Core.Context.StaRunner.Run(() =>",
        "{",
        "    var form = new Form();",
        "    form.Text = \"Folder Preview\";",
        "    form.Width = 700;",
        "    form.Height = 600;",
        "    form.StartPosition = FormStartPosition.CenterScreen;",
        "    form.TopMost = true;",
        "    form.Shown += (s, e) => { form.TopMost = true; form.Activate(); form.BringToFront(); form.Focus(); };",
        "",
        "    var tree = new TreeView();",
        "    tree.Dock = DockStyle.Fill;",
        "    tree.HideSelection = false;",
        "",
        "    int maxDepth = 4;",
        "    int maxNodes = 2000;",
        "    int nodeCount = 0;",
        "",
        "    TreeNode Build(string path, int depth)",
        "    {",
        "        var node = new TreeNode(Path.GetFileName(path));",
        "        node.Tag = path;",
        "        if (depth >= maxDepth) return node;",
        "        try",
        "        {",
        "            foreach (var d in Directory.GetDirectories(path))",
        "            {",
        "                if (nodeCount++ > maxNodes) break;",
        "                node.Nodes.Add(Build(d, depth + 1));",
        "            }",
        "            foreach (var f in Directory.GetFiles(path))",
        "            {",
        "                if (nodeCount++ > maxNodes) break;",
        "                node.Nodes.Add(new TreeNode(Path.GetFileName(f)) { Tag = f });",
        "            }",
        "        }",
        "        catch { }",
        "        return node;",
        "    }",
        "",
        "    var root = Build(dir, 0);",
        "    root.Text = Path.GetFileName(dir);",
        "    tree.Nodes.Add(root);",
        "    root.Expand();",
        "",
        "    form.Controls.Add(tree);",
        "    form.ShowDialog();",
        "});"
      ]
    }
  ]
}