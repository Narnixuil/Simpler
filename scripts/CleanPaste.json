{
  "name": "Clean Paste",
  "description": "Normalize copied text (remove extra spaces/lines)",
  "icon": "🧹",
  "steps": [
    {
      "op": "csharp",
      "codeLines": [
        "using System;",
        "using System.Linq;",
        "using System.Text.RegularExpressions;",
        "using Simpler.Core.Models;",
        "",
        "async System.Threading.Tasks.Task Run(ScriptContext context)",
        "{",
        "    string text = \"\";",
        "    try",
        "    {",
        "        text = Simpler.Core.Context.StaRunner.Run(() => System.Windows.Forms.Clipboard.ContainsText() ? System.Windows.Forms.Clipboard.GetText() : \"\");",
        "    }",
        "    catch { }",
        "    if (string.IsNullOrWhiteSpace(text)) return;",
        "",
        "    var norm = text.Replace(\"\\r\\n\", \"\\n\").Replace(\"\\r\", \"\\n\");",
        "    var lines = norm.Split('\\n').Select(l => l.Trim()).Where(l => l.Length > 0);",
        "    var joined = string.Join(\" \", lines);",
        "    joined = Regex.Replace(joined, \"\\\\s+\", \" \").Trim();",
        "    if (joined.Length == 0) return;",
        "    context.SetOutputText(joined);",
        "}"
      ]
    }
  ]
}