{
    "icon":  "🧹",
    "description":  "Normalize copied text (remove extra spaces/lines)",
    "name":  "Clean Paste",
    "steps":  [
                  {
                      "codeLines":  [
                                        "using System;",
                                        "using System.Collections.Generic;",
                                        "using System.Linq;",
                                        "using System.Text;",
                                        "using Simpler.Core.Models;",
                                        "",
                                        "async System.Threading.Tasks.Task Run(ScriptContext context)",
                                        "{",
                                        "    string text = \"\";",
                                        "    try",
                                        "    {",
                                        "        text = Simpler.Core.Context.StaRunner.Run(() => System.Windows.Forms.Clipboard.ContainsText() ? System.Windows.Forms.Clipboard.GetText() : \"\");",
                                        "    }",
                                        "    catch { }",
                                        "    if (string.IsNullOrWhiteSpace(text)) { context.Notify(\"Clipboard is empty.\"); return; }",
                                        "",
                                        "    var norm = text.Replace(\"\\r\\n\", \"\\n\").Replace(\"\\r\", \"\\n\");",
                                        "",
                                        "    var toChinese = new Dictionary<char, char>",
                                        "    {",
                                        "        [','] = '，',",
                                        "        ['.'] = '。',",
                                        "        ['?'] = '？',",
                                        "        ['!'] = '！',",
                                        "        [':'] = '：',",
                                        "        [';'] = '；',",
                                        "        ['('] = '（',",
                                        "        [')'] = '）',",
                                        "        ['['] = '【',",
                                        "        [']'] = '】',",
                                        "        ['{'] = '｛',",
                                        "        ['}'] = '｝',",
                                        "        ['<'] = '《',",
                                        "        ['>'] = '》'",
                                        "    };",
                                        "    var toEnglish = toChinese.ToDictionary(k => k.Value, v => v.Key);",
                                        "    var englishPunct = new HashSet<char>(toChinese.Keys);",
                                        "    var chinesePunct = new HashSet<char>(toChinese.Values);",
                                        "    var trailingEnglishPunct = new HashSet<char>(new [] { ',', '.', '?', '!', ':', ';' });",
                                        "",
                                        "    bool IsChineseChar(char c)",
                                        "    {",
                                        "        return (c >= '\\u4E00' && c <= '\\u9FFF')",
                                        "            || (c >= '\\u3400' && c <= '\\u4DBF')",
                                        "            || (c >= '\\uF900' && c <= '\\uFAFF');",
                                        "    }",
                                        "",
                                        "    bool IsEnglishChar(char c)",
                                        "    {",
                                        "        return c <= '\\u007F' && (char.IsLetterOrDigit(c));",
                                        "    }",
                                        "",
                                        "    bool IsPunct(char c)",
                                        "    {",
                                        "        return englishPunct.Contains(c) || chinesePunct.Contains(c);",
                                        "    }",
                                        "",
                                        "    int GetPrevNonWs(int start)",
                                        "    {",
                                        "        for (int i = start - 1; i >= 0; i--)",
                                        "        {",
                                        "            if (!char.IsWhiteSpace(norm[i])) return i;",
                                        "        }",
                                        "        return -1;",
                                        "    }",
                                        "",
                                        "    int GetNextNonWs(int start)",
                                        "    {",
                                        "        for (int i = start + 1; i < norm.Length; i++)",
                                        "        {",
                                        "            if (!char.IsWhiteSpace(norm[i])) return i;",
                                        "        }",
                                        "        return -1;",
                                        "    }",
                                        "",
                                        "    char GetPrevWordChar(int start)",
                                        "    {",
                                        "        for (int i = start - 1; i >= 0; i--)",
                                        "        {",
                                        "            char c = norm[i];",
                                        "            if (char.IsWhiteSpace(c)) continue;",
                                        "            if (IsPunct(c)) continue;",
                                        "            return c;",
                                        "        }",
                                        "        return '\\0';",
                                        "    }",
                                        "",
                                        "    char GetNextWordChar(int start)",
                                        "    {",
                                        "        for (int i = start + 1; i < norm.Length; i++)",
                                        "        {",
                                        "            char c = norm[i];",
                                        "            if (char.IsWhiteSpace(c)) continue;",
                                        "            if (IsPunct(c)) continue;",
                                        "            return c;",
                                        "        }",
                                        "        return '\\0';",
                                        "    }",
                                        "",
                                        "    int GetPunctLang(int index)",
                                        "    {",
                                        "        char l = GetPrevWordChar(index);",
                                        "        char r = GetNextWordChar(index);",
                                        "        bool lZh = l != '\\0' && IsChineseChar(l);",
                                        "        bool rZh = r != '\\0' && IsChineseChar(r);",
                                        "        bool lEn = l != '\\0' && IsEnglishChar(l);",
                                        "        bool rEn = r != '\\0' && IsEnglishChar(r);",
                                        "        if (lZh && rZh) return 1;",
                                        "        if (lEn && rEn) return 2;",
                                        "        return 0;",
                                        "    }",
                                        "",
                                        "    int n = norm.Length;",
                                        "    var sb = new StringBuilder(n);",
                                        "    for (int i = 0; i < n; i++)",
                                        "    {",
                                        "        char ch = norm[i];",
                                        "        if (char.IsWhiteSpace(ch))",
                                        "        {",
                                        "            int j = i;",
                                        "            while (j + 1 < n && char.IsWhiteSpace(norm[j + 1])) j++;",
                                        "            int l = GetPrevNonWs(i);",
                                        "            int r = GetNextNonWs(j);",
                                        "            i = j;",
                                        "",
                                        "            if (l < 0 || r < 0) continue;",
                                        "",
                                        "            char lc = norm[l];",
                                        "            char rc = norm[r];",
                                        "            bool lP = IsPunct(lc);",
                                        "            bool rP = IsPunct(rc);",
                                        "",
                                        "            if (rP)",
                                        "            {",
                                        "                // Remove space before punctuation",
                                        "                continue;",
                                        "            }",
                                        "",
                                        "            if (lP)",
                                        "            {",
                                        "                int lang = GetPunctLang(l);",
                                        "                if (lang == 1) continue; // Chinese punctuation: no space after",
                                        "                if (lang == 2 && trailingEnglishPunct.Contains(toEnglish.ContainsKey(lc) ? toEnglish[lc] : lc)) { sb.Append(' '); continue; }",
                                        "                continue;",
                                        "            }",
                                        "",
                                        "            bool lZh = IsChineseChar(lc);",
                                        "            bool rZh = IsChineseChar(rc);",
                                        "            bool lEn = IsEnglishChar(lc);",
                                        "            bool rEn = IsEnglishChar(rc);",
                                        "",
                                        "            if (lZh && rZh) continue;",
                                        "            if (lEn && rEn) { sb.Append(' '); continue; }",
                                        "",
                                        "            sb.Append(' ');",
                                        "            continue;",
                                        "        }",
                                        "",
                                        "        if (IsPunct(ch))",
                                        "        {",
                                        "            int lang = GetPunctLang(i);",
                                        "            if (lang == 1 && toChinese.ContainsKey(ch)) ch = toChinese[ch];",
                                        "            else if (lang == 2 && toEnglish.ContainsKey(ch)) ch = toEnglish[ch];",
                                        "            sb.Append(ch);",
                                        "            continue;",
                                        "        }",
                                        "",
                                        "        sb.Append(ch);",
                                        "    }",
                                        "",
                                        "    var result = sb.ToString().Trim();",
                                        "    if (result.Length == 0) return;",
                                        "    context.SetOutputText(result);",
                                        "}"
                                    ],
                      "op":  "csharp"
                  }
              ]
}
