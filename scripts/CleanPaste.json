                      "codeLines":  [
                                        "using System;",
                                        "using System.Linq;",
                                        "using Simpler.Core.Models;",
                                        "",
                                        "async System.Threading.Tasks.Task Run(ScriptContext context)",
                                        "{",
                                        "    string text = \"\";",
                                        "    try",
                                        "    {",
                                        "        text = Simpler.Core.Context.StaRunner.Run(() =\u003e System.Windows.Forms.Clipboard.ContainsText() ? System.Windows.Forms.Clipboard.GetText() : \"\");",
                                        "    }",
                                        "    catch { }",
                                        "    if (string.IsNullOrWhiteSpace(text)) { context.Notify(\"Clipboard is empty.\"); return; }",
                                        "",
                                        "    var norm = text.Replace(\"\\r\\n\", \"\\n\").Replace(\"\\r\", \"\\n\");",
                                        "    var parts = norm.Split(\"\\n\").Select(l =\u003e l.Trim()).Where(l =\u003e l.Length \u003e 0);",
                                        "    var joined = string.Concat(parts);",
                                        "    if (joined.Length == 0) return;",
                                        "    context.SetOutputText(joined);",
                                        "}"
                                    ],
                      "op":  "csharp"
                  }
              ]
