{
  "name": "EVER Rename",
  "icon": "✏️",
  "description": "Batch rename files with a dedicated editor",
  "captureMode": "passive",
  "steps": [
    {
      "op": "csharp",
      "codeLines": [
        "var files = context.SelectedFiles;",
        "if (files == null || files.Count == 0) { context.Notify(\"No files selected.\"); return; }",
        "var renameMap = Simpler.Core.Context.StaRunner.Run(() =>",
        "{",
        "    var form = new Form();",
        "    form.Text = \"EVER Rename\";",
        "    form.Width = 900;",
        "    form.Height = 700;",
        "    form.StartPosition = FormStartPosition.CenterScreen;",
        "    form.TopMost = true;",
        "    form.Shown += (s, e) => { form.TopMost = true; form.Activate(); form.BringToFront(); form.Focus(); };",
        "",
        "    var originalExts = files.Select(f => Path.GetExtension(f) ?? \"\").ToList();",
        "    var baseNames = files.Select(f => Path.GetFileNameWithoutExtension(f) ?? \"\").ToList();",
        "",
        "    var editor = new TextBox();",
        "    editor.Multiline = true;",
        "    editor.ScrollBars = ScrollBars.Vertical;",
        "    editor.WordWrap = false;",
        "    editor.Dock = DockStyle.Fill;",
        "    editor.Font = new Font(\"Consolas\", 12);",
        "",
        "    var showExtBox = new CheckBox { Text = \"Show extension\", Checked = false, AutoSize = true };",
        "    var findToggleBtn = new Button { Text = \"Find/Replace\", AutoSize = true };",
        "",
        "    var regexBox = new CheckBox { Text = \"Regex\", Checked = false, AutoSize = true };",
        "    var findBox = new TextBox { Width = 180 };",
        "    var replaceBox = new TextBox { Width = 180 };",
        "    var replaceBtn = new Button { Text = \"Replace All\", AutoSize = true };",
        "",
        "    List<string> GetLines(string text)",
        "    {",
        "        var list = text.Replace(\"\\r\\n\", \"\\n\").Replace(\"\\r\", \"\\n\").Split('\\n').ToList();",
        "        if (list.Count > 0 && list[^1] == \"\") list.RemoveAt(list.Count - 1);",
        "        return list;",
        "    }",
        "",
        "    Action SyncFromEditor = () =>",
        "    {",
        "        var lines = GetLines(editor.Text);",
        "        if (lines.Count != files.Count) return;",
        "        var next = new List<string>(lines.Count);",
        "        for (int i = 0; i < lines.Count; i++)",
        "        {",
        "            var line = (lines[i] ?? \"\").Trim();",
        "            if (showExtBox.Checked)",
        "            {",
        "                next.Add(Path.GetFileNameWithoutExtension(line) ?? \"\");",
        "            }",
        "            else",
        "            {",
        "                var ext = originalExts[i];",
        "                if (!string.IsNullOrEmpty(ext) && line.EndsWith(ext, StringComparison.OrdinalIgnoreCase))",
        "                    line = line.Substring(0, line.Length - ext.Length);",
        "                next.Add(line);",
        "            }",
        "        }",
        "        baseNames = next;",
        "    };",
        "",
        "    Action RefreshEditor = () =>",
        "    {",
        "        if (showExtBox.Checked)",
        "            editor.Lines = baseNames.Select((b, i) => b + originalExts[i]).ToArray();",
        "        else",
        "            editor.Lines = baseNames.ToArray();",
        "    };",
        "",
        "    showExtBox.CheckedChanged += (s, e) => { SyncFromEditor(); RefreshEditor(); };",
        "",
        "    replaceBtn.Click += (s, e) =>",
        "    {",
        "        if (string.IsNullOrEmpty(findBox.Text)) return;",
        "        if (regexBox.Checked)",
        "            editor.Text = Regex.Replace(editor.Text, findBox.Text, replaceBox.Text ?? \"\");",
        "        else",
        "            editor.Text = editor.Text.Replace(findBox.Text, replaceBox.Text ?? \"\");",
        "    };",
        "",
        "    var optionsPanel = new FlowLayoutPanel();",
        "    optionsPanel.Dock = DockStyle.Top;",
        "    optionsPanel.AutoSize = true;",
        "    optionsPanel.WrapContents = true;",
        "    optionsPanel.Controls.Add(showExtBox);",
        "    optionsPanel.Controls.Add(findToggleBtn);",
        "",
        "    var findPanel = new FlowLayoutPanel();",
        "    findPanel.Dock = DockStyle.Top;",
        "    findPanel.AutoSize = true;",
        "    findPanel.WrapContents = true;",
        "    findPanel.Visible = false;",
        "    findPanel.Controls.Add(new Label { Text = \"Find\", AutoSize = true, TextAlign = ContentAlignment.MiddleLeft });",
        "    findPanel.Controls.Add(findBox);",
        "    findPanel.Controls.Add(new Label { Text = \"Replace\", AutoSize = true, TextAlign = ContentAlignment.MiddleLeft });",
        "    findPanel.Controls.Add(replaceBox);",
        "    findPanel.Controls.Add(regexBox);",
        "    findPanel.Controls.Add(replaceBtn);",
        "",
        "    findToggleBtn.Click += (s, e) => { findPanel.Visible = !findPanel.Visible; };",
        "",
        "    var buttonsPanel = new FlowLayoutPanel();",
        "    buttonsPanel.Dock = DockStyle.Bottom;",
        "    buttonsPanel.AutoSize = true;",
        "    buttonsPanel.FlowDirection = FlowDirection.RightToLeft;",
        "    var okBtn = new Button { Text = \"OK\", AutoSize = true };",
        "    var cancelBtn = new Button { Text = \"Cancel\", AutoSize = true };",
        "    buttonsPanel.Controls.Add(okBtn);",
        "    buttonsPanel.Controls.Add(cancelBtn);",
        "",
        "    var main = new TableLayoutPanel();",
        "    main.Dock = DockStyle.Fill;",
        "    main.RowCount = 4;",
        "    main.ColumnCount = 1;",
        "    main.RowStyles.Add(new RowStyle(SizeType.AutoSize));",
        "    main.RowStyles.Add(new RowStyle(SizeType.AutoSize));",
        "    main.RowStyles.Add(new RowStyle(SizeType.Percent, 100));",
        "    main.RowStyles.Add(new RowStyle(SizeType.AutoSize));",
        "    main.Controls.Add(optionsPanel, 0, 0);",
        "    main.Controls.Add(findPanel, 0, 1);",
        "    main.Controls.Add(editor, 0, 2);",
        "    main.Controls.Add(buttonsPanel, 0, 3);",
        "    form.Controls.Add(main);",
        "",
        "    RefreshEditor();",
        "",
        "    Dictionary<string, string>? result = null;",
        "    okBtn.Click += (s, e) =>",
        "    {",
        "        SyncFromEditor();",
        "        var lines = baseNames;",
        "        if (lines.Count != files.Count)",
        "        {",
        "            MessageBox.Show(\"Line count must match file count.\", \"EVER Rename\", MessageBoxButtons.OK, MessageBoxIcon.Warning);",
        "            return;",
        "        }",
        "",
        "        var newNames = new List<string>();",
        "        for (int i = 0; i < files.Count; i++)",
        "        {",
        "            var name = (lines[i] ?? \"\").Trim();",
        "            if (string.IsNullOrWhiteSpace(name))",
        "            {",
        "                MessageBox.Show(\"File name cannot be empty.\", \"EVER Rename\", MessageBoxButtons.OK, MessageBoxIcon.Warning);",
        "                return;",
        "            }",
        "            name += originalExts[i];",
        "            if (name.IndexOfAny(Path.GetInvalidFileNameChars()) >= 0)",
        "            {",
        "                MessageBox.Show(\"Invalid characters in file name: \" + name, \"EVER Rename\", MessageBoxButtons.OK, MessageBoxIcon.Warning);",
        "                return;",
        "            }",
        "            newNames.Add(name);",
        "        }",
        "",
        "        var dup = newNames.GroupBy(n => n, StringComparer.OrdinalIgnoreCase).FirstOrDefault(g => g.Count() > 1);",
        "        if (dup != null)",
        "        {",
        "            MessageBox.Show(\"Duplicate file name detected: \" + dup.Key, \"EVER Rename\", MessageBoxButtons.OK, MessageBoxIcon.Warning);",
        "            return;",
        "        }",
        "",
        "        var selectedSet = new HashSet<string>(files, StringComparer.OrdinalIgnoreCase);",
        "        for (int i = 0; i < files.Count; i++)",
        "        {",
        "            var dir = Path.GetDirectoryName(files[i]) ?? \"\";",
        "            var newPath = Path.Combine(dir, newNames[i]);",
        "            if (File.Exists(newPath) && !selectedSet.Contains(newPath))",
        "            {",
        "                MessageBox.Show(\"Target already exists: \" + newNames[i], \"EVER Rename\", MessageBoxButtons.OK, MessageBoxIcon.Warning);",
        "                return;",
        "            }",
        "        }",
        "",
        "        result = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);",
        "        for (int i = 0; i < files.Count; i++)",
        "        {",
        "            var oldName = Path.GetFileName(files[i]) ?? \"\";",
        "            if (!string.Equals(oldName, newNames[i], StringComparison.Ordinal))",
        "                result[files[i]] = newNames[i];",
        "        }",
        "",
        "        form.DialogResult = DialogResult.OK;",
        "        form.Close();",
        "    };",
        "",
        "    cancelBtn.Click += (s, e) => { form.DialogResult = DialogResult.Cancel; form.Close(); };",
        "    form.FormClosing += (s, e) => { if (form.DialogResult != DialogResult.OK) result = null; };",
        "",
        "    return form.ShowDialog() == DialogResult.OK ? result : null;",
        "});",
        "",
        "if (renameMap == null) return;",
        "foreach (var kv in renameMap)",
        "    context.RenameFile(kv.Key, kv.Value);",
        "context.Notify(\"Rename list prepared.\");"
      ]
    }
  ]
}
