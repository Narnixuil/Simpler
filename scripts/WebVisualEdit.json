{
  "name": "Web Visual Edit",
  "description": "Enable visual editing on the current web page",
  "icon": "🧪",
  "steps": [
    {
      "op": "csharp",
      "codeLines": [
        "using System;",
        "using System.Collections.Generic;",
        "using System.Runtime.InteropServices;",
        "using System.Threading;",
        "using Simpler.Core.Models;",
        "",
        "[StructLayout(LayoutKind.Sequential)]",
        "struct INPUT { public uint type; public InputUnion U; }",
        "[StructLayout(LayoutKind.Explicit)]",
        "struct InputUnion { [FieldOffset(0)] public KEYBDINPUT ki; }",
        "[StructLayout(LayoutKind.Sequential)]",
        "struct KEYBDINPUT { public ushort wVk; public ushort wScan; public uint dwFlags; public uint time; public IntPtr dwExtraInfo; }",
        "[DllImport(\"user32.dll\", SetLastError = true)]",
        "static extern uint SendInput(uint nInputs, INPUT[] pInputs, int cbSize);",
        "const uint INPUT_KEYBOARD = 1;",
        "const uint KEYEVENTF_UNICODE = 0x0004;",
        "const uint KEYEVENTF_KEYUP = 0x0002;",
        "",
        "static void SendUnicode(string text)",
        "{",
        "    var inputs = new List<INPUT>();",
        "    foreach (var ch in text)",
        "    {",
        "        inputs.Add(new INPUT { type = INPUT_KEYBOARD, U = new InputUnion { ki = new KEYBDINPUT { wVk = 0, wScan = ch, dwFlags = KEYEVENTF_UNICODE, time = 0, dwExtraInfo = IntPtr.Zero } } });",
        "        inputs.Add(new INPUT { type = INPUT_KEYBOARD, U = new InputUnion { ki = new KEYBDINPUT { wVk = 0, wScan = ch, dwFlags = KEYEVENTF_UNICODE | KEYEVENTF_KEYUP, time = 0, dwExtraInfo = IntPtr.Zero } } });",
        "    }",
        "    if (inputs.Count > 0) SendInput((uint)inputs.Count, inputs.ToArray(), Marshal.SizeOf(typeof(INPUT)));",
        "}",
        "",
        "async System.Threading.Tasks.Task Run(ScriptContext context)",
        "{",
        "    var js = \"javascript:document.body.contentEditable='true';document.designMode='on';void0\";",
        "    try",
        "    {",
        "        Simpler.Core.Context.StaRunner.Run(() =>",
        "        {",
        "            System.Windows.Forms.SendKeys.SendWait(\"{ESC}\");",
        "            System.Windows.Forms.SendKeys.SendWait(\"{ESC}\");",
        "            Thread.Sleep(50);",
        "            System.Windows.Forms.SendKeys.SendWait(\"%d\");",
        "            Thread.Sleep(80);",
        "            System.Windows.Forms.SendKeys.SendWait(\"^l\");",
        "            Thread.Sleep(80);",
        "            System.Windows.Forms.SendKeys.SendWait(\"^a\");",
        "            Thread.Sleep(30);",
        "            System.Windows.Forms.SendKeys.SendWait(\"{BACKSPACE}\");",
        "            Thread.Sleep(30);",
        "            SendUnicode(js);",
        "            Thread.Sleep(60);",
        "            System.Windows.Forms.SendKeys.SendWait(\"{ENTER}\");",
        "        });",
        "    }",
        "    catch (Exception ex)",
        "    {",
        "        Simpler.Core.Logging.Write($\"WebVisualEdit failed: {ex}\");",
        "    }",
        "}"
      ]
    }
  ]
}