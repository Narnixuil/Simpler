{
    "icon": "WEB",
    "description": "Enable in-page visual editing by typing a javascript: URL into the address bar",
    "name": "Web Visual Edit",
    "steps": [
        {
            "op": "csharp",
            "codeLines": [
                "using System;",
                "using System.IO;",
                "using System.Runtime.InteropServices;",
                "using Simpler.Core.Models;",
                "",
                "static class InputLayout",
                "{",
                "    const uint WM_INPUTLANGCHANGEREQUEST = 0x0050;",
                "    const uint KLF_ACTIVATE = 0x00000001;",
                "",
                "    [DllImport(\"user32.dll\")] static extern IntPtr GetForegroundWindow();",
                "    [DllImport(\"user32.dll\")] static extern IntPtr SendMessage(IntPtr hWnd, uint Msg, IntPtr wParam, IntPtr lParam);",
                "    [DllImport(\"user32.dll\")] static extern IntPtr LoadKeyboardLayout(string pwszKLID, uint Flags);",
                "    [DllImport(\"user32.dll\")] static extern IntPtr GetKeyboardLayout(uint idThread);",
                "    [DllImport(\"user32.dll\")] static extern uint GetWindowThreadProcessId(IntPtr hWnd, IntPtr lpdwProcessId);",
                "    [DllImport(\"imm32.dll\")] static extern IntPtr ImmGetContext(IntPtr hWnd);",
                "    [DllImport(\"imm32.dll\")] static extern bool ImmSetOpenStatus(IntPtr hIMC, bool fOpen);",
                "    [DllImport(\"imm32.dll\")] static extern bool ImmReleaseContext(IntPtr hWnd, IntPtr hIMC);",
                "",
                "    public static void SaveAndSwitch()",
                "    {",
                "        var hwnd = GetForegroundWindow();",
                "        if (hwnd == IntPtr.Zero) return;",
                "        uint threadId = GetWindowThreadProcessId(hwnd, IntPtr.Zero);",
                "        var hkl = GetKeyboardLayout(threadId);",
                "        var path = Path.Combine(Path.GetTempPath(), \"simpler_input_layout.txt\");",
                "        File.WriteAllText(path, hkl.ToInt64().ToString());",
                "",
                "        var hIMC = ImmGetContext(hwnd);",
                "        if (hIMC != IntPtr.Zero)",
                "        {",
                "            ImmSetOpenStatus(hIMC, false);",
                "            ImmReleaseContext(hwnd, hIMC);",
                "        }",
                "",
                "        var en = LoadKeyboardLayout(\"00000409\", KLF_ACTIVATE);",
                "        SendMessage(hwnd, WM_INPUTLANGCHANGEREQUEST, IntPtr.Zero, en);",
                "    }",
                "}",
                "",
                "async System.Threading.Tasks.Task Run(ScriptContext context)",
                "{",
                "    InputLayout.SaveAndSwitch();",
                "}"
            ]
        },
        {
            "op": "simulatekey",
            "keys": "Ctrl+L",
            "preDelayMs": 120,
            "postDelayMs": 180
        },
        {
            "op": "simulateinput",
            "text": "javascript:document.body.contentEditable='true';document.designMode='on';void0",
            "perCharDelayMs": 0,
            "preDelayMs": 120,
            "ensureEnglish": true
        },
        {
            "op": "simulatekey",
            "keys": "{ENTER}",
            "normalize": false,
            "preDelayMs": 80
        },
        {
            "op": "csharp",
            "codeLines": [
                "using System;",
                "using System.IO;",
                "using System.Runtime.InteropServices;",
                "using Simpler.Core.Models;",
                "",
                "static class InputLayoutRestore",
                "{",
                "    const uint WM_INPUTLANGCHANGEREQUEST = 0x0050;",
                "    [DllImport(\"user32.dll\")] static extern IntPtr GetForegroundWindow();",
                "    [DllImport(\"user32.dll\")] static extern IntPtr SendMessage(IntPtr hWnd, uint Msg, IntPtr wParam, IntPtr lParam);",
                "",
                "    public static void Restore()",
                "    {",
                "        var path = Path.Combine(Path.GetTempPath(), \"simpler_input_layout.txt\");",
                "        if (!File.Exists(path)) return;",
                "        if (!long.TryParse(File.ReadAllText(path).Trim(), out var value)) return;",
                "        var hkl = new IntPtr(value);",
                "        var hwnd = GetForegroundWindow();",
                "        if (hwnd == IntPtr.Zero) return;",
                "        SendMessage(hwnd, WM_INPUTLANGCHANGEREQUEST, IntPtr.Zero, hkl);",
                "        try { File.Delete(path); } catch { }",
                "    }",
                "}",
                "",
                "async System.Threading.Tasks.Task Run(ScriptContext context)",
                "{",
                "    InputLayoutRestore.Restore();",
                "}"
            ]
        }
    ]
}