{
  "name": "Search Everything",
  "icon": "🔎",
  "description": "Search selected text or filename in Everything",
  "steps": [
    {
      "op": "csharp",
      "codeLines": [
        "string FindScriptsDir()",
        "{",
        "    try",
        "    {",
        "        var dir = new DirectoryInfo(AppDomain.CurrentDomain.BaseDirectory);",
        "        DirectoryInfo? cur = dir;",
        "        for (int i = 0; i < 8 && cur != null; i++)",
        "        {",
        "            var candidate = Path.Combine(cur.FullName, \"scripts\");",
        "            if (Directory.Exists(candidate)) return candidate;",
        "            cur = cur.Parent;",
        "        }",
        "    }",
        "    catch { }",
        "    return Path.Combine(AppDomain.CurrentDomain.BaseDirectory, \"scripts\");",
        "}",
        "",
        "var query = context.SelectedText;",
        "if (string.IsNullOrWhiteSpace(query) && context.SelectedFiles.Count > 0) query = Path.GetFileName(context.SelectedFiles[0]);",
        "",
        "var settingsPath = Path.Combine(FindScriptsDir(), \"_everything_path.txt\");",
        "string exe = \"\";",
        "if (File.Exists(settingsPath)) exe = (File.ReadAllText(settingsPath) ?? \"\").Trim();",
        "",
        "if (string.IsNullOrWhiteSpace(exe) || !File.Exists(exe))",
        "{",
        "    exe = Simpler.Core.Context.StaRunner.Run(() =>",
        "    {",
        "        using var dialog = new OpenFileDialog",
        "        {",
        "            Title = \"Locate Everything.exe\",",
        "            Filter = \"Everything (Everything.exe)|Everything.exe|Executables (*.exe)|*.exe\",",
        "            CheckFileExists = true,",
        "            CheckPathExists = true",
        "        };",
        "        return dialog.ShowDialog() == DialogResult.OK ? dialog.FileName : \"\";",
        "    });",
        "    if (!string.IsNullOrWhiteSpace(exe))",
        "    {",
        "        try { File.WriteAllText(settingsPath, exe); } catch { }",
        "    }",
        "}",
        "",
        "if (string.IsNullOrWhiteSpace(exe) || !File.Exists(exe)) { context.Notify(\"Everything.exe not set.\"); return; }",
        "try",
        "{",
        "    var psi = new System.Diagnostics.ProcessStartInfo { FileName = exe, UseShellExecute = true };",
        "    if (!string.IsNullOrWhiteSpace(query))",
        "    {",
        "        psi.ArgumentList.Add(\"-search\");",
        "        psi.ArgumentList.Add(query);",
        "    }",
        "    System.Diagnostics.Process.Start(psi);",
        "}",
        "catch (Exception ex)",
        "{",
        "    context.Notify(\"Failed to launch Everything.\");",
        "    Simpler.Core.Logging.Write($\"Everything launch failed: {ex}\");",
        "}"
      ]
    }
  ]
}
