{
  "name": "Unlock and Delete",
  "icon": "🗑️",
  "description": "Force close locking processes and delete selected files or folders",
  "steps": [
    {
      "op": "csharp",
      "codeLines": [
        "using System;",
        "using System.Collections.Generic;",
        "using System.Diagnostics;",
        "using System.IO;",
        "using System.Linq;",
        "using System.Runtime.InteropServices;",
        "using System.Runtime.InteropServices.ComTypes;",
        "using System.Threading;",
        "using System.Drawing;",
        "using System.Windows.Forms;",
        "",
        "async System.Threading.Tasks.Task Run(ScriptContext context)",
        "{",
        "    if (context.SelectedFiles.Count == 0)",
        "    {",
        "        context.Notify(\"No selected files or folders.\");",
        "        return;",
        "    }",
        "",
        "    bool TryDeletePath(string path, out string error)",
        "    {",
        "        error = \"\";",
        "        try",
        "        {",
        "            if (Directory.Exists(path))",
        "            {",
        "                Directory.Delete(path, true);",
        "                return true;",
        "            }",
        "            if (File.Exists(path))",
        "            {",
        "                File.Delete(path);",
        "                return true;",
        "            }",
        "            error = \"Path not found.\";",
        "            return false;",
        "        }",
        "        catch (Exception ex)",
        "        {",
        "            error = ex.Message;",
        "            return false;",
        "        }",
        "    }",
        "",
        "    List<Process> GetLockingProcesses(string path)",
        "    {",
        "        const int ERROR_MORE_DATA = 234;",
        "        uint handle = 0;",
        "        var key = Guid.NewGuid().ToString();",
        "        var result = RmStartSession(out handle, 0, key);",
        "        if (result != 0) return new List<Process>();",
        "",
        "        try",
        "        {",
        "            string[] resources = new[] { path };",
        "            result = RmRegisterResources(handle, (uint)resources.Length, resources, 0, null, 0, null);",
        "            if (result != 0) return new List<Process>();",
        "",
        "            uint pnProcInfoNeeded = 0;",
        "            uint pnProcInfo = 0;",
        "            uint rebootReasons = 0;",
        "            result = RmGetList(handle, out pnProcInfoNeeded, ref pnProcInfo, null, ref rebootReasons);",
        "            if (result == ERROR_MORE_DATA)",
        "            {",
        "                var infos = new RM_PROCESS_INFO[pnProcInfoNeeded];",
        "                pnProcInfo = pnProcInfoNeeded;",
        "                result = RmGetList(handle, out pnProcInfoNeeded, ref pnProcInfo, infos, ref rebootReasons);",
        "                if (result == 0)",
        "                {",
        "                    var processes = new List<Process>();",
        "                    var seen = new HashSet<int>();",
        "                    for (int i = 0; i < pnProcInfo; i++)",
        "                    {",
        "                        int pid = infos[i].Process.dwProcessId;",
        "                        if (pid <= 0 || !seen.Add(pid)) continue;",
        "                        try",
        "                        {",
        "                            processes.Add(Process.GetProcessById(pid));",
        "                        }",
        "                        catch { }",
        "                    }",
        "                    return processes;",
        "                }",
        "            }",
        "            return new List<Process>();",
        "        }",
        "        finally",
        "        {",
        "            RmEndSession(handle);",
        "        }",
        "    }",
        "",
        "    foreach (var path in context.SelectedFiles)",
        "    {",
        "        if (string.IsNullOrWhiteSpace(path)) continue;",
        "",
        "        if (TryDeletePath(path, out var error))",
        "        {",
        "            context.Notify($\"Deleted: {path}\");",
        "            continue;",
        "        }",
        "",
        "        var lockers = GetLockingProcesses(path);",
        "        if (lockers.Count == 0)",
        "        {",
        "            context.Notify($\"Failed to delete: {path}. {error}\");",
        "            continue;",
        "        }",
        "",
        "        var list = string.Join(\"\\n\", lockers.Select(p => $\"{p.ProcessName} (PID {p.Id})\"));",
        "        var warning = \"\\n\\nWarning: some processes may have unsaved work.\";",
        "",
        "        var confirm = Simpler.Core.Context.StaRunner.Run(() =>",
        "        {",
        "            var text = $\"The path is in use:\\n{path}\\n\\nLocking processes:\\n{list}{warning}\\n\\nForce close these processes and retry delete?\";",
        "            using var owner = new Form",
        "            {",
        "                TopMost = true,",
        "                ShowInTaskbar = false,",
        "                StartPosition = FormStartPosition.CenterScreen,",
        "                Size = new Size(1, 1),",
        "                Opacity = 0,",
        "                FormBorderStyle = FormBorderStyle.None",
        "            };",
        "            owner.Shown += (_, __) => owner.Activate();",
        "            owner.Show();",
        "            return MessageBox.Show(owner, text, \"Unlock and Delete\", MessageBoxButtons.YesNo, MessageBoxIcon.Warning) == DialogResult.Yes;",
        "        });",
        "",
        "        if (!confirm)",
        "        {",
        "            context.Notify($\"Skipped: {path}\");",
        "            continue;",
        "        }",
        "",
        "        var killed = new List<string>();",
        "        foreach (var p in lockers)",
        "        {",
        "            try",
        "            {",
        "                if (p.HasExited) continue;",
        "                p.Kill();",
        "                p.WaitForExit(2000);",
        "                killed.Add($\"{p.ProcessName} (PID {p.Id})\");",
        "            }",
        "            catch (Exception ex)",
        "            {",
        "                Simpler.Core.Logging.Write($\"UnlockDelete kill failed: {p.ProcessName} (PID {p.Id})\\n{ex}\");",
        "            }",
        "        }",
        "",
        "        Thread.Sleep(500);",
        "        if (TryDeletePath(path, out var error2))",
        "        {",
        "            var killedText = killed.Count > 0 ? string.Join(\", \", killed) : \"none\";",
        "            context.Notify($\"Deleted: {path}. Killed: {killedText}\");",
        "        }",
        "        else",
        "        {",
        "            context.Notify($\"Failed to delete: {path}. {error2}\");",
        "        }",
        "    }",
        "}",
        "",
        "[DllImport(\"rstrtmgr.dll\", CharSet = CharSet.Unicode)]",
        "static extern int RmStartSession(out uint pSessionHandle, int dwSessionFlags, string strSessionKey);",
        "",
        "[DllImport(\"rstrtmgr.dll\", CharSet = CharSet.Unicode)]",
        "static extern int RmRegisterResources(uint pSessionHandle, uint nFiles, string[] rgsFilenames, uint nApplications, RM_UNIQUE_PROCESS[] rgApplications, uint nServices, string[] rgsServiceNames);",
        "",
        "[DllImport(\"rstrtmgr.dll\", CharSet = CharSet.Unicode)]",
        "static extern int RmGetList(uint dwSessionHandle, out uint pnProcInfoNeeded, ref uint pnProcInfo, [In, Out] RM_PROCESS_INFO[] rgAffectedApps, ref uint lpdwRebootReasons);",
        "",
        "[DllImport(\"rstrtmgr.dll\", CharSet = CharSet.Unicode)]",
        "static extern int RmEndSession(uint pSessionHandle);",
        "",
        "[StructLayout(LayoutKind.Sequential)]",
        "struct RM_UNIQUE_PROCESS",
        "{",
        "    public int dwProcessId;",
        "    public FILETIME ProcessStartTime;",
        "}",
        "",
        "enum RM_APP_TYPE",
        "{",
        "    RmUnknownApp = 0,",
        "    RmMainWindow = 1,",
        "    RmOtherWindow = 2,",
        "    RmService = 3,",
        "    RmExplorer = 4,",
        "    RmConsole = 5,",
        "    RmCritical = 1000",
        "}",
        "",
        "[StructLayout(LayoutKind.Sequential, CharSet = CharSet.Unicode)]",
        "struct RM_PROCESS_INFO",
        "{",
        "    public RM_UNIQUE_PROCESS Process;",
        "    [MarshalAs(UnmanagedType.ByValTStr, SizeConst = 256)]",
        "    public string strAppName;",
        "    [MarshalAs(UnmanagedType.ByValTStr, SizeConst = 64)]",
        "    public string strServiceShortName;",
        "    public RM_APP_TYPE ApplicationType;",
        "    public uint AppStatus;",
        "    public uint TSSessionId;",
        "    [MarshalAs(UnmanagedType.Bool)]",
        "    public bool bRestartable;",
        "}"
      ]
    }
  ]
}
