{
  "name": "Power Paste",
  "icon": "⚡",
  "description": "Queue clipboard text and paste sequentially",
  "captureMode": "passive",
  "steps": [
    {
      "codeLines": [
        "using System;",
        "using System.Collections.Generic;",
        "using System.Drawing;",
        "using System.Runtime.InteropServices;",
        "using System.Threading;",
        "using System.Windows.Forms;",
        "using Simpler.Core.Models;",
        "using Simpler.Core.Context;",
        "",
        "class PowerPasteSession : Form",
        "{",
        "    const int WM_CLIPBOARDUPDATE = 0x031D;",
        "    const int WM_HOTKEY = 0x0312;",
        "    const uint MOD_CONTROL = 0x0002;",
        "    const uint MOD_NOREPEAT = 0x4000;",
        "    const uint VK_V = 0x56;",
        "    const uint VK_ESCAPE = 0x1B;",
        "",
        "    [DllImport(\"user32.dll\")] static extern bool AddClipboardFormatListener(IntPtr hwnd);",
        "    [DllImport(\"user32.dll\")] static extern bool RemoveClipboardFormatListener(IntPtr hwnd);",
        "    [DllImport(\"user32.dll\")] static extern bool RegisterHotKey(IntPtr hWnd, int id, uint fsModifiers, uint vk);",
        "    [DllImport(\"user32.dll\")] static extern bool UnregisterHotKey(IntPtr hWnd, int id);",
        "    [DllImport(\"user32.dll\")] static extern uint GetClipboardSequenceNumber();",
        "",
        "    readonly Queue<string> _queue = new();",
        "    string _lastText = \"\";",
        "    uint _lastSeq = 0;",
        "    bool _suppressClipboard = false;",
        "    System.Windows.Forms.Timer? _suppressTimer;",
        "",
        "    Form? _status;",
        "    Label? _statusLabel;",
        "",
        "    protected override void OnHandleCreated(EventArgs e)",
        "    {",
        "        base.OnHandleCreated(e);",
        "        AddClipboardFormatListener(Handle);",
        "        RegisterHotKey(Handle, 1, MOD_CONTROL | MOD_NOREPEAT, VK_V);",
        "        RegisterHotKey(Handle, 2, MOD_NOREPEAT, VK_ESCAPE);",
        "        ShowStatus();",
        "        UpdateStatus();",
        "        ShowToast(\"PowerPaste started (Esc to exit)\");",
        "    }",
        "",
        "    protected override void OnFormClosed(FormClosedEventArgs e)",
        "    {",
        "        RemoveClipboardFormatListener(Handle);",
        "        UnregisterHotKey(Handle, 1);",
        "        UnregisterHotKey(Handle, 2);",
        "        _status?.Close();",
        "        base.OnFormClosed(e);",
        "    }",
        "",
        "    protected override void WndProc(ref Message m)",
        "    {",
        "        if (m.Msg == WM_CLIPBOARDUPDATE)",
        "        {",
        "            OnClipboardUpdate();",
        "            return;",
        "        }",
        "        if (m.Msg == WM_HOTKEY)",
        "        {",
        "            if (m.WParam == (IntPtr)1) { HandlePaste(); return; }",
        "            if (m.WParam == (IntPtr)2) { ShowToast(\"Exited\"); Close(); return; }",
        "        }",
        "        base.WndProc(ref m);",
        "    }",
        "",
        "    void OnClipboardUpdate()",
        "    {",
        "        if (_suppressClipboard) return;",
        "",
        "        uint seq = GetClipboardSequenceNumber();",
        "        if (seq == _lastSeq) return;",
        "",
        "        string text = SafeGetClipboardText();",
        "        if (string.IsNullOrWhiteSpace(text)) return;",
        "        if (text == _lastText) { _lastSeq = seq; return; }",
        "",
        "        _lastSeq = seq;",
        "        _lastText = text;",
        "        _queue.Enqueue(text);",
        "        UpdateStatus();",
        "        ShowToast($\"{_queue.Count} item(s) queued\");",
        "    }",
        "",
        "    void HandlePaste()",
        "    {",
        "        if (_queue.Count == 0)",
        "        {",
        "            ShowToast(\"Queue is empty. Ending session.\");",
        "            Close();",
        "            return;",
        "        }",
        "",
        "        string text = _queue.Dequeue();",
        "        SuppressClipboardTemporarily();",
        "        SafeSetClipboardText(text);",
        "",
        "        UnregisterHotKey(Handle, 1);",
        "        SendKeys.SendWait(\"^v\");",
        "        Thread.Sleep(30);",
        "        RegisterHotKey(Handle, 1, MOD_CONTROL | MOD_NOREPEAT, VK_V);",
        "",
        "        UpdateStatus();",
        "        if (_queue.Count == 0)",
        "        {",
        "            ShowToast(\"All items pasted.\");",
        "            Close();",
        "        }",
        "    }",
        "",
        "    void SuppressClipboardTemporarily()",
        "    {",
        "        _suppressClipboard = true;",
        "        _suppressTimer ??= new System.Windows.Forms.Timer();",
        "        _suppressTimer.Interval = 200;",
        "        _suppressTimer.Tick += (s, e) => { _suppressTimer!.Stop(); _suppressClipboard = false; };",
        "        _suppressTimer.Stop();",
        "        _suppressTimer.Start();",
        "    }",
        "",
        "    void ShowStatus()",
        "    {",
        "        _status = new Form",
        "        {",
        "            FormBorderStyle = FormBorderStyle.None,",
        "            StartPosition = FormStartPosition.Manual,",
        "            TopMost = true,",
        "            Width = 260,",
        "            Height = 30,",
        "            BackColor = Color.FromArgb(30, 30, 30),",
        "            ShowInTaskbar = false",
        "        };",
        "        _statusLabel = new Label",
        "        {",
        "            ForeColor = Color.White,",
        "            Dock = DockStyle.Fill,",
        "            TextAlign = ContentAlignment.MiddleCenter",
        "        };",
        "        _status.Controls.Add(_statusLabel);",
        "        var screen = Screen.PrimaryScreen.WorkingArea;",
        "        _status.Left = screen.Right - _status.Width - 20;",
        "        _status.Top = screen.Bottom - _status.Height - 80;",
        "        _status.Show();",
        "    }",
        "",
        "    void UpdateStatus()",
        "    {",
        "        if (_statusLabel != null)",
        "        {",
        "            _statusLabel.Text = $\"PowerPaste: {_queue.Count} in queue (Esc to exit)\";",
        "        }",
        "    }",
        "",
        "    string SafeGetClipboardText()",
        "    {",
        "        try { return Clipboard.ContainsText() ? Clipboard.GetText() : \"\"; }",
        "        catch { return \"\"; }",
        "    }",
        "",
        "    void SafeSetClipboardText(string text)",
        "    {",
        "        try { Clipboard.SetText(text); } catch { }",
        "    }",
        "",
        "    void ShowToast(string message)",
        "    {",
        "        var toast = new Form",
        "        {",
        "            FormBorderStyle = FormBorderStyle.None,",
        "            StartPosition = FormStartPosition.Manual,",
        "            TopMost = true,",
        "            Width = 240,",
        "            Height = 50,",
        "            BackColor = Color.FromArgb(30, 30, 30),",
        "            ShowInTaskbar = false",
        "        };",
        "        var label = new Label",
        "        {",
        "            Text = message,",
        "            ForeColor = Color.White,",
        "            Dock = DockStyle.Fill,",
        "            TextAlign = ContentAlignment.MiddleCenter",
        "        };",
        "        toast.Controls.Add(label);",
        "        var screen = Screen.PrimaryScreen.WorkingArea;",
        "        toast.Left = screen.Right - toast.Width - 20;",
        "        toast.Top = screen.Bottom - toast.Height - 20;",
        "        var timer = new System.Windows.Forms.Timer { Interval = 1200 };",
        "        timer.Tick += (s, e) => { timer.Stop(); toast.Close(); };",
        "        toast.Shown += (s, e) => timer.Start();",
        "        toast.Show();",
        "    }",
        "}",
        "",
        "async System.Threading.Tasks.Task Run(ScriptContext context)",
        "{",
        "    StaRunner.Run(() => Application.Run(new PowerPasteSession()));",
        "}"
      ],
      "op": "csharp"
    }
  ]
}

