{
    "name":  "Screenshot Blur",
    "icon":  "◌",
    "description":  "Screenshot with blurred background highlight",
    "steps":  [
                  {
                      "codeLines":  [
                                        "using System;",
                                        "using System.IO;",
                                        "using System.Drawing;",
                                        "using System.Drawing.Imaging;",
                                        "using System.Drawing.Drawing2D;",
                                        "using System.Runtime.InteropServices;",
                                        "using System.Windows.Forms;",
                                        "using Simpler.Core.Models;",
                                        "using Simpler.Core.Context;",
                                        "",
                                        "async System.Threading.Tasks.Task Run(ScriptContext context)",
                                        "{",
                                        "    Bitmap? bmpA = BlurCaptureScreenshot();",
                                        "    if (bmpA == null)",
                                        "    {",
                                        "        BlurShowToast(\"Cancelled\");",
                                        "        return;",
                                        "    }",
                                        "",
                                        "    Rectangle? regionB = StaRunner.Run(() =\u003e ",
                                        "BlurImageRegionSelector",
                                        ".SelectRegion(bmpA));",
                                        "    if (regionB == null || regionB.Value.Width \u003c 2 || regionB.Value.Height \u003c 2)",
                                        "    {",
                                        "        bmpA.Dispose();",
                                        "        BlurShowToast(\"Cancelled\");",
                                        "        return;",
                                        "    }",
                                        "",
                                        "    using var result = ",
                                        "BlurApplyBlurWithClear",
                                        "(bmpA, regionB.Value, ",
                                        "8",
                                        ");",
                                        "    bmpA.Dispose();",
                                        "",
                                        "    StaRunner.Run(() =\u003e",
                                        "    {",
                                        "        using var clip = (Bitmap)result.Clone();",
                                        "        Clipboard.SetImage(clip);",
                                        "    });",
                                        "",
                                        "    ",
                                        "BlurShowToast",
                                        "(\"Screenshot copied to clipboard.\");",
                                        "}",
                                        "Bitmap? BlurCaptureScreenshot()",
                                        "{",
                                        "    Rectangle? region = StaRunner.Run(() =\u003e BlurScreenRegionSelector.SelectRegion());",
                                        "    if (region == null || region.Value.Width \u003c 2 || region.Value.Height \u003c 2)",
                                        "    {",
                                        "        return null;",
                                        "    }",
                                        "",
                                        "    Rectangle r = region.Value;",
                                        "    var bmp = new Bitmap(r.Width, r.Height, PixelFormat.Format32bppArgb);",
                                        "    using (var g = Graphics.FromImage(bmp))",
                                        "    {",
                                        "        g.CopyFromScreen(r.Left, r.Top, 0, 0, new Size(r.Width, r.Height), CopyPixelOperation.SourceCopy);",
                                        "    }",
                                        "    return bmp;",
                                        "}",
                                        "",
                                        "Bitmap BlurApplyBlurWithClear(Bitmap source, Rectangle clearRect, int radius)",
                                        "{",
                                        "    using var blurred = BlurBoxBlur(source, radius);",
                                        "    var output = new Bitmap(source.Width, source.Height, PixelFormat.Format32bppArgb);",
                                        "    using (var g = Graphics.FromImage(output))",
                                        "    {",
                                        "        g.DrawImage(blurred, 0, 0);",
                                        "        g.DrawImage(source, clearRect, clearRect, GraphicsUnit.Pixel);",
                                        "    }",
                                        "    return output;",
                                        "}",
                                        "",
                                        "Bitmap BlurBoxBlur(Bitmap source, int radius)",
                                        "{",
                                        "    if (radius \u003c 1) return (Bitmap)source.Clone();",
                                        "    int w = source.Width;",
                                        "    int h = source.Height;",
                                        "    var rect = new Rectangle(0, 0, w, h);",
                                        "    var src = source.LockBits(rect, ImageLockMode.ReadOnly, PixelFormat.Format32bppArgb);",
                                        "    int stride = src.Stride;",
                                        "    int bytes = stride * h;",
                                        "    var buffer = new byte[bytes];",
                                        "    Marshal.Copy(src.Scan0, buffer, 0, bytes);",
                                        "    source.UnlockBits(src);",
                                        "",
                                        "    var temp = new byte[bytes];",
                                        "    var dest = new byte[bytes];",
                                        "    int r = radius;",
                                        "    int div = r * 2 + 1;",
                                        "",
                                        "    // horizontal pass",
                                        "    for (int y = 0; y \u003c h; y++)",
                                        "    {",
                                        "        int row = y * stride;",
                                        "        int aSum = 0, rSum = 0, gSum = 0, bSum = 0;",
                                        "        for (int x = -r; x \u003c= r; x++)",
                                        "        {",
                                        "            int cx = x \u003c 0 ? 0 : (x \u003e= w ? w - 1 : x);",
                                        "            int idx = row + cx * 4;",
                                        "            bSum += buffer[idx + 0];",
                                        "            gSum += buffer[idx + 1];",
                                        "            rSum += buffer[idx + 2];",
                                        "            aSum += buffer[idx + 3];",
                                        "        }",
                                        "        for (int x = 0; x \u003c w; x++)",
                                        "        {",
                                        "            int outIdx = row + x * 4;",
                                        "            temp[outIdx + 0] = (byte)(bSum / div);",
                                        "            temp[outIdx + 1] = (byte)(gSum / div);",
                                        "            temp[outIdx + 2] = (byte)(rSum / div);",
                                        "            temp[outIdx + 3] = (byte)(aSum / div);",
                                        "",
                                        "            int left = x - r;",
                                        "            int right = x + r + 1;",
                                        "            if (left \u003c 0) left = 0;",
                                        "            if (right \u003e= w) right = w - 1;",
                                        "            int idxL = row + left * 4;",
                                        "            int idxR = row + right * 4;",
                                        "            bSum += buffer[idxR + 0] - buffer[idxL + 0];",
                                        "            gSum += buffer[idxR + 1] - buffer[idxL + 1];",
                                        "            rSum += buffer[idxR + 2] - buffer[idxL + 2];",
                                        "            aSum += buffer[idxR + 3] - buffer[idxL + 3];",
                                        "        }",
                                        "    }",
                                        "",
                                        "    // vertical pass",
                                        "    for (int x = 0; x \u003c w; x++)",
                                        "    {",
                                        "        int aSum = 0, rSum = 0, gSum = 0, bSum = 0;",
                                        "        for (int y = -r; y \u003c= r; y++)",
                                        "        {",
                                        "            int cy = y \u003c 0 ? 0 : (y \u003e= h ? h - 1 : y);",
                                        "            int idx = cy * stride + x * 4;",
                                        "            bSum += temp[idx + 0];",
                                        "            gSum += temp[idx + 1];",
                                        "            rSum += temp[idx + 2];",
                                        "            aSum += temp[idx + 3];",
                                        "        }",
                                        "        for (int y = 0; y \u003c h; y++)",
                                        "        {",
                                        "            int outIdx = y * stride + x * 4;",
                                        "            dest[outIdx + 0] = (byte)(bSum / div);",
                                        "            dest[outIdx + 1] = (byte)(gSum / div);",
                                        "            dest[outIdx + 2] = (byte)(rSum / div);",
                                        "            dest[outIdx + 3] = (byte)(aSum / div);",
                                        "",
                                        "            int top = y - r;",
                                        "            int bottom = y + r + 1;",
                                        "            if (top \u003c 0) top = 0;",
                                        "            if (bottom \u003e= h) bottom = h - 1;",
                                        "            int idxT = top * stride + x * 4;",
                                        "            int idxB = bottom * stride + x * 4;",
                                        "            bSum += temp[idxB + 0] - temp[idxT + 0];",
                                        "            gSum += temp[idxB + 1] - temp[idxT + 1];",
                                        "            rSum += temp[idxB + 2] - temp[idxT + 2];",
                                        "            aSum += temp[idxB + 3] - temp[idxT + 3];",
                                        "        }",
                                        "    }",
                                        "",
                                        "    var output = new Bitmap(w, h, PixelFormat.Format32bppArgb);",
                                        "    var dst = output.LockBits(rect, ImageLockMode.WriteOnly, PixelFormat.Format32bppArgb);",
                                        "    Marshal.Copy(dest, 0, dst.Scan0, bytes);",
                                        "    output.UnlockBits(dst);",
                                        "    return output;",
                                        "}",
                                        "",
                                        "void BlurShowToast(string message)",
                                        "{",
                                        "    StaRunner.Run(() =\u003e",
                                        "    {",
                                        "        var toast = new System.Windows.Forms.Form",
                                        "        {",
                                        "            FormBorderStyle = System.Windows.Forms.FormBorderStyle.None,",
                                        "            StartPosition   = System.Windows.Forms.FormStartPosition.Manual,",
                                        "            TopMost = true,",
                                        "            Width = 320,",
                                        "            Height = 60,",
                                        "            BackColor = System.Drawing.Color.FromArgb(30, 30, 30),",
                                        "            ShowInTaskbar = false",
                                        "        };",
                                        "        var label = new System.Windows.Forms.Label",
                                        "        {",
                                        "            Text = message,",
                                        "            ForeColor = System.Drawing.Color.White,",
                                        "            Dock = System.Windows.Forms.DockStyle.Fill,",
                                        "            TextAlign = System.Drawing.ContentAlignment.MiddleCenter",
                                        "        };",
                                        "        toast.Controls.Add(label);",
                                        "        var screen = System.Windows.Forms.Screen.PrimaryScreen!.WorkingArea;",
                                        "        toast.Left = screen.Right - toast.Width - 20;",
                                        "        toast.Top  = screen.Bottom - toast.Height - 20;",
                                        "        toast.Shown += async (s, e) =\u003e",
                                        "        {",
                                        "            await System.Threading.Tasks.Task.Delay(3000);",
                                        "            toast.Close();",
                                        "        };",
                                        "        System.Windows.Forms.Application.Run(toast);",
                                        "    });",
                                        "}",
                                        "",
                                        "static Rectangle BlurNormalizeRect(Point a, Point b)",
                                        "{",
                                        "    int x1 = Math.Min(a.X, b.X);",
                                        "    int y1 = Math.Min(a.Y, b.Y);",
                                        "    int x2 = Math.Max(a.X, b.X);",
                                        "    int y2 = Math.Max(a.Y, b.Y);",
                                        "    return new Rectangle(x1, y1, x2 - x1, y2 - y1);",
                                        "}",
                                        "",
                                        "static Rectangle BlurClampRect(Rectangle r, Rectangle bounds)",
                                        "{",
                                        "    int x = Math.Max(bounds.X, Math.Min(r.X, bounds.Right - 1));",
                                        "    int y = Math.Max(bounds.Y, Math.Min(r.Y, bounds.Bottom - 1));",
                                        "    int right = Math.Min(r.Right, bounds.Right);",
                                        "    int bottom = Math.Min(r.Bottom, bounds.Bottom);",
                                        "    int w = Math.Max(0, right - x);",
                                        "    int h = Math.Max(0, bottom - y);",
                                        "    return new Rectangle(x, y, w, h);",
                                        "}",
                                        "",
                                        "static void BlurForceForeground(Form form)",
                                        "{",
                                        "    try",
                                        "    {",
                                        "        form.TopMost = true;",
                                        "        form.BringToFront();",
                                        "        form.Activate();",
                                        "        BlurBringWindowToTop(form.Handle);",
                                        "        BlurSetForegroundWindow(form.Handle);",
                                        "    }",
                                        "    catch { }",
                                        "}",
                                        "",
                                        "[DllImport(\"user32.dll\")] static extern bool BlurSetForegroundWindow(IntPtr hWnd);",
                                        "[DllImport(\"user32.dll\")] static extern bool BlurBringWindowToTop(IntPtr hWnd);",
                                        "",
                                        "class BlurScreenRegionSelector : Form",
                                        "{",
                                        "    private Point _start;",
                                        "    private Rectangle _selection;",
                                        "    private bool _dragging;",
                                        "    private Bitmap _background;",
                                        "    private Rectangle _virtualScreen;",
                                        "",
                                        "    public Rectangle Selected { get; private set; }",
                                        "",
                                        "    public static Rectangle? SelectRegion()",
                                        "    {",
                                        "        using var f = new BlurScreenRegionSelector();",
                                        "        return f.ShowDialog() == DialogResult.OK ? f.Selected : (Rectangle?)null;",
                                        "    }",
                                        "",
                                        "    public BlurScreenRegionSelector()",
                                        "    {",
                                        "        FormBorderStyle = FormBorderStyle.None;",
                                        "        Shown += (_, _) =\u003e BlurForceForeground(this);",
                                        "        StartPosition = FormStartPosition.Manual;",
                                        "        TopMost = true;",
                                        "        ShowInTaskbar = false;",
                                        "        DoubleBuffered = true;",
                                        "        KeyPreview = true;",
                                        "        Cursor = Cursors.Cross;",
                                        "",
                                        "        _virtualScreen = SystemInformation.VirtualScreen;",
                                        "        Bounds = _virtualScreen;",
                                        "",
                                        "        _background = new Bitmap(_virtualScreen.Width, _virtualScreen.Height, PixelFormat.Format32bppArgb);",
                                        "        using (var g = Graphics.FromImage(_background))",
                                        "        {",
                                        "            g.CopyFromScreen(_virtualScreen.Left, _virtualScreen.Top, 0, 0, _virtualScreen.Size, CopyPixelOperation.SourceCopy);",
                                        "        }",
                                        "    }",
                                        "",
                                        "    protected override void OnPaint(PaintEventArgs e)",
                                        "    {",
                                        "        var g = e.Graphics;",
                                        "        g.DrawImage(_background, 0, 0);",
                                        "        using var dimBrush = new SolidBrush(Color.FromArgb(120, 0, 0, 0));",
                                        "        g.FillRectangle(dimBrush, 0, 0, Width, Height);",
                                        "        if (_selection.Width \u003e 0 \u0026\u0026 _selection.Height \u003e 0)",
                                        "        {",
                                        "            var state = g.Save();",
                                        "            g.SetClip(_selection);",
                                        "            g.DrawImage(_background, 0, 0);",
                                        "            g.Restore(state);",
                                        "            using var pen = new Pen(Color.Lime, 2);",
                                        "            g.DrawRectangle(pen, _selection);",
                                        "        }",
                                        "    }",
                                        "",
                                        "    protected override void OnMouseDown(MouseEventArgs e)",
                                        "    {",
                                        "        if (e.Button != MouseButtons.Left) return;",
                                        "        _dragging = true;",
                                        "        _start = e.Location;",
                                        "        _selection = new Rectangle(_start, new Size(0, 0));",
                                        "        Invalidate();",
                                        "    }",
                                        "",
                                        "    protected override void OnMouseMove(MouseEventArgs e)",
                                        "    {",
                                        "        if (!_dragging) return;",
                                        "        _selection = BlurNormalizeRect(_start, e.Location);",
                                        "        Invalidate();",
                                        "    }",
                                        "",
                                        "    protected override void OnMouseUp(MouseEventArgs e)",
                                        "    {",
                                        "        if (!_dragging) return;",
                                        "        _dragging = false;",
                                        "        _selection = BlurNormalizeRect(_start, e.Location);",
                                        "        if (_selection.Width \u003e 1 \u0026\u0026 _selection.Height \u003e 1)",
                                        "        {",
                                        "            Selected = new Rectangle(_selection.X + _virtualScreen.Left, _selection.Y + _virtualScreen.Top, _selection.Width, _selection.Height);",
                                        "            DialogResult = DialogResult.OK;",
                                        "        }",
                                        "        else",
                                        "        {",
                                        "            DialogResult = DialogResult.Cancel;",
                                        "        }",
                                        "        Close();",
                                        "    }",
                                        "",
                                        "    protected override void OnKeyDown(KeyEventArgs e)",
                                        "    {",
                                        "        if (e.KeyCode == Keys.Escape)",
                                        "        {",
                                        "            DialogResult = DialogResult.Cancel;",
                                        "            Close();",
                                        "        }",
                                        "    }",
                                        "",
                                        "    protected override void OnFormClosed(FormClosedEventArgs e)",
                                        "    {",
                                        "        _background.Dispose();",
                                        "        base.OnFormClosed(e);",
                                        "    }",
                                        "}",
                                        "",
                                        "class BlurImageRegionSelector : Form",
                                        "{",
                                        "    private Bitmap _image;",
                                        "    private float _scale;",
                                        "    private Rectangle _selection;",
                                        "    private bool _dragging;",
                                        "    private Point _start;",
                                        "",
                                        "    public Rectangle Selected { get; private set; }",
                                        "",
                                        "    public static Rectangle? SelectRegion(Bitmap source)",
                                        "    {",
                                        "        using var f = new BlurImageRegionSelector(source);",
                                        "        return f.ShowDialog() == DialogResult.OK ? f.Selected : (Rectangle?)null;",
                                        "    }",
                                        "",
                                        "    public BlurImageRegionSelector(Bitmap source)",
                                        "    {",
                                        "        FormBorderStyle = FormBorderStyle.FixedDialog;",
                                        "        Shown += (_, _) =\u003e BlurForceForeground(this);",
                                        "        StartPosition = FormStartPosition.CenterScreen;",
                                        "        TopMost = true;",
                                        "        ShowInTaskbar = false;",
                                        "        DoubleBuffered = true;",
                                        "        KeyPreview = true;",
                                        "        Cursor = Cursors.Cross;",
                                        "",
                                        "        _image = (Bitmap)source.Clone();",
                                        "",
                                        "        var max = Screen.PrimaryScreen.WorkingArea;",
                                        "        int maxW = Math.Max(200, max.Width - 80);",
                                        "        int maxH = Math.Max(200, max.Height - 120);",
                                        "        _scale = 1f;",
                                        "        if (_image.Width \u003e maxW || _image.Height \u003e maxH)",
                                        "        {",
                                        "            float sx = (float)maxW / _image.Width;",
                                        "            float sy = (float)maxH / _image.Height;",
                                        "            _scale = Math.Min(sx, sy);",
                                        "        }",
                                        "        int w = (int)Math.Round(_image.Width * _scale);",
                                        "        int h = (int)Math.Round(_image.Height * _scale);",
                                        "        ClientSize = new Size(w, h);",
                                        "    }",
                                        "",
                                        "    protected override void OnPaint(PaintEventArgs e)",
                                        "    {",
                                        "        var g = e.Graphics;",
                                        "        g.InterpolationMode = InterpolationMode.HighQualityBicubic;",
                                        "        var target = new Rectangle(0, 0, ClientSize.Width, ClientSize.Height);",
                                        "        g.DrawImage(_image, target);",
                                        "        using var dimBrush = new SolidBrush(Color.FromArgb(120, 0, 0, 0));",
                                        "        g.FillRectangle(dimBrush, 0, 0, ClientSize.Width, ClientSize.Height);",
                                        "        if (_selection.Width \u003e 0 \u0026\u0026 _selection.Height \u003e 0)",
                                        "        {",
                                        "            var state = g.Save();",
                                        "            g.SetClip(_selection);",
                                        "            g.DrawImage(_image, target);",
                                        "            g.Restore(state);",
                                        "            using var pen = new Pen(Color.Lime, 2);",
                                        "            g.DrawRectangle(pen, _selection);",
                                        "        }",
                                        "    }",
                                        "",
                                        "    protected override void OnMouseDown(MouseEventArgs e)",
                                        "    {",
                                        "        if (e.Button != MouseButtons.Left) return;",
                                        "        _dragging = true;",
                                        "        _start = e.Location;",
                                        "        _selection = new Rectangle(_start, new Size(0, 0));",
                                        "        Invalidate();",
                                        "    }",
                                        "",
                                        "    protected override void OnMouseMove(MouseEventArgs e)",
                                        "    {",
                                        "        if (!_dragging) return;",
                                        "        _selection = BlurNormalizeRect(_start, e.Location);",
                                        "        Invalidate();",
                                        "    }",
                                        "",
                                        "    protected override void OnMouseUp(MouseEventArgs e)",
                                        "    {",
                                        "        if (!_dragging) return;",
                                        "        _dragging = false;",
                                        "        _selection = BlurNormalizeRect(_start, e.Location);",
                                        "        if (_selection.Width \u003e 1 \u0026\u0026 _selection.Height \u003e 1)",
                                        "        {",
                                        "            int x = (int)Math.Round(_selection.X / _scale);",
                                        "            int y = (int)Math.Round(_selection.Y / _scale);",
                                        "            int w = (int)Math.Round(_selection.Width / _scale);",
                                        "            int h = (int)Math.Round(_selection.Height / _scale);",
                                        "            var mapped = new Rectangle(x, y, w, h);",
                                        "            mapped = BlurClampRect(mapped, new Rectangle(0, 0, _image.Width, _image.Height));",
                                        "            if (mapped.Width \u003e 1 \u0026\u0026 mapped.Height \u003e 1)",
                                        "            {",
                                        "                Selected = mapped;",
                                        "                DialogResult = DialogResult.OK;",
                                        "            }",
                                        "            else",
                                        "            {",
                                        "                DialogResult = DialogResult.Cancel;",
                                        "            }",
                                        "        }",
                                        "        else",
                                        "        {",
                                        "            DialogResult = DialogResult.Cancel;",
                                        "        }",
                                        "        Close();",
                                        "    }",
                                        "",
                                        "    protected override void OnKeyDown(KeyEventArgs e)",
                                        "    {",
                                        "        if (e.KeyCode == Keys.Escape)",
                                        "        {",
                                        "            DialogResult = DialogResult.Cancel;",
                                        "            Close();",
                                        "        }",
                                        "    }",
                                        "",
                                        "    protected override void OnFormClosed(FormClosedEventArgs e)",
                                        "    {",
                                        "        _image.Dispose();",
                                        "        base.OnFormClosed(e);",
                                        "    }",
                                        "}"
                                    ],
                      "op":  "csharp"
                  }
              ]
}
