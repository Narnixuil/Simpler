{
  "name": "Pin Window",
  "description": "Toggle topmost for the active window",
  "icon": "📌",
  "steps": [
    {
      "op": "csharp",
      "codeLines": [
        "using System;",
        "using System.Runtime.InteropServices;",
        "using System.Text;",
        "using Simpler.Core.Models;",
        "",
        "static class Native",
        "{",
        "    public delegate bool EnumWindowsProc(IntPtr hWnd, IntPtr lParam);",
        "    [DllImport(\"user32.dll\")] public static extern IntPtr GetForegroundWindow();",
        "    [DllImport(\"user32.dll\", SetLastError=true)] public static extern int GetWindowLong(IntPtr hWnd, int nIndex);",
        "    [DllImport(\"user32.dll\", SetLastError=true)] public static extern bool SetWindowPos(IntPtr hWnd, IntPtr hWndInsertAfter, int X, int Y, int cx, int cy, uint uFlags);",
        "    [DllImport(\"user32.dll\", CharSet = CharSet.Unicode)] public static extern int GetWindowText(IntPtr hWnd, StringBuilder lpString, int nMaxCount);",
        "    [DllImport(\"user32.dll\", CharSet = CharSet.Unicode)] public static extern int GetWindowTextLength(IntPtr hWnd);",
        "    [DllImport(\"user32.dll\")] public static extern bool EnumWindows(EnumWindowsProc lpEnumFunc, IntPtr lParam);",
        "    [DllImport(\"user32.dll\")] public static extern bool IsWindowVisible(IntPtr hWnd);",
        "}",
        "",
        "const int GWL_EXSTYLE = -20;",
        "const int WS_EX_TOPMOST = 0x00000008;",
        "const uint SWP_NOMOVE = 0x0002;",
        "const uint SWP_NOSIZE = 0x0001;",
        "static readonly IntPtr HWND_TOPMOST = new IntPtr(-1);",
        "static readonly IntPtr HWND_NOTOPMOST = new IntPtr(-2);",
        "",
        "async System.Threading.Tasks.Task Run(ScriptContext context)",
        "{",
        "    string desiredTitle = context.ActiveWindowTitle ?? \"\";",
        "    IntPtr hwnd = GetTargetWindow(desiredTitle);",
        "    if (hwnd == IntPtr.Zero) return;",
        "    string title = GetTitle(hwnd);",
        "",
        "    int exStyle = Native.GetWindowLong(hwnd, GWL_EXSTYLE);",
        "    bool isTopmost = (exStyle & WS_EX_TOPMOST) != 0;",
        "    IntPtr insertAfter = isTopmost ? HWND_NOTOPMOST : HWND_TOPMOST;",
        "    if (!Native.SetWindowPos(hwnd, insertAfter, 0, 0, 0, 0, SWP_NOMOVE | SWP_NOSIZE)) return;",
        "    if (!isTopmost)",
        "    {",
        "        ShowToast(string.IsNullOrWhiteSpace(title) ? \"Pinned\" : $\"Pinned {title}\");",
        "    }",
        "}",
        "",
        "IntPtr GetTargetWindow(string desiredTitle)",
        "{",
        "    System.Threading.Thread.Sleep(200);",
        "    IntPtr hwnd = Native.GetForegroundWindow();",
        "    string title = GetTitle(hwnd);",
        "    if (!string.IsNullOrWhiteSpace(title) && !IsSimplerTitle(title)) return hwnd;",
        "",
        "    if (!string.IsNullOrWhiteSpace(desiredTitle) && !IsSimplerTitle(desiredTitle))",
        "    {",
        "        var match = FindWindowByTitle(desiredTitle);",
        "        if (match != IntPtr.Zero) return match;",
        "    }",
        "",
        "    for (int i = 0; i < 50; i++)",
        "    {",
        "        System.Threading.Thread.Sleep(100);",
        "        hwnd = Native.GetForegroundWindow();",
        "        title = GetTitle(hwnd);",
        "        if (!string.IsNullOrWhiteSpace(title) && !IsSimplerTitle(title)) return hwnd;",
        "    }",
        "    return hwnd;",
        "}",
        "",
        "IntPtr FindWindowByTitle(string desiredTitle)",
        "{",
        "    IntPtr found = IntPtr.Zero;",
        "    Native.EnumWindows((hWnd, lParam) =>",
        "    {",
        "        if (!Native.IsWindowVisible(hWnd)) return true;",
        "        string t = GetTitle(hWnd);",
        "        if (string.Equals(t, desiredTitle, StringComparison.OrdinalIgnoreCase))",
        "        {",
        "            found = hWnd;",
        "            return false;",
        "        }",
        "        return true;",
        "    }, IntPtr.Zero);",
        "    return found;",
        "}",
        "",
        "bool IsSimplerTitle(string title)",
        "{",
        "    return string.Equals(title, \"Simpler\", StringComparison.OrdinalIgnoreCase);",
        "}",
        "",
        "string GetTitle(IntPtr hWnd)",
        "{",
        "    if (hWnd == IntPtr.Zero) return string.Empty;",
        "    int len = Native.GetWindowTextLength(hWnd);",
        "    if (len <= 0) return string.Empty;",
        "    var sb = new StringBuilder(len + 1);",
        "    Native.GetWindowText(hWnd, sb, sb.Capacity);",
        "    return sb.ToString();",
        "}",
        "",
        "void ShowToast(string message)",
        "{",
        "    Simpler.Core.Context.StaRunner.Run(() =>",
        "    {",
        "        var toast = new System.Windows.Forms.Form();",
        "        toast.FormBorderStyle = System.Windows.Forms.FormBorderStyle.None;",
        "        toast.StartPosition = System.Windows.Forms.FormStartPosition.Manual;",
        "        toast.TopMost = true;",
        "        toast.Width = 300;",
        "        toast.Height = 60;",
        "        toast.BackColor = System.Drawing.Color.FromArgb(30, 30, 30);",
        "        toast.ShowInTaskbar = false;",
        "        var label = new System.Windows.Forms.Label();",
        "        label.Text = message;",
        "        label.ForeColor = System.Drawing.Color.White;",
        "        label.Dock = System.Windows.Forms.DockStyle.Fill;",
        "        label.TextAlign = System.Drawing.ContentAlignment.MiddleCenter;",
        "        toast.Controls.Add(label);",
        "        var screen = System.Windows.Forms.Screen.PrimaryScreen.WorkingArea;",
        "        toast.Left = screen.Right - toast.Width - 20;",
        "        toast.Top = screen.Bottom - toast.Height - 20;",
        "        var timer = new System.Windows.Forms.Timer();",
        "        timer.Interval = 3000;",
        "        timer.Tick += (s, e) => { timer.Stop(); toast.Close(); };",
        "        toast.Shown += (s, e) => timer.Start();",
        "        toast.Show();",
        "        System.Windows.Forms.Application.DoEvents();",
        "    });",
        "}"
      ]
    }
  ]
}