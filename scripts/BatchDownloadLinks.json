{
  "name": "Batch Download Links",
  "icon": "🔗",
  "description": "Download files from URLs in selected text",
  "steps": [
    {
      "codeLines": [
        "using System;",
        "using System.IO;",
        "using System.Linq;",
        "using System.Net.Http;",
        "using System.Text.RegularExpressions;",
        "using System.Collections.Generic;",
        "using System.Windows.Forms;",
        "using Simpler.Core.Models;",
        "using Simpler.Core.Context;",
        "",
        "async System.Threading.Tasks.Task Run(ScriptContext context)",
        "{",
        "    string text = context.SelectedText;",
        "    if (string.IsNullOrWhiteSpace(text))",
        "    {",
        "        try { text = StaRunner.Run(() => Clipboard.ContainsText() ? Clipboard.GetText() : \"\"); } catch { }",
        "    }",
        "",
        "    string html = \"\";",
        "    try",
        "    {",
        "        StaRunner.Run(() =>",
        "        {",
        "            SendKeys.SendWait(\"^c\");",
        "            System.Threading.Thread.Sleep(80);",
        "            if (Clipboard.ContainsData(DataFormats.Html))",
        "                html = Clipboard.GetData(DataFormats.Html) as string ?? \"\";",
        "        });",
        "    }",
        "    catch { }",
        "",
        "    var urls = new List<string>();",
        "",
        "    string source = !string.IsNullOrWhiteSpace(html) ? html : text;",
        "    if (string.IsNullOrWhiteSpace(source)) { context.Notify(\"No text found.\"); return; }",
        "",
        "    foreach (Match m in Regex.Matches(source, @\"href\\s*=\\s*\"\"([^\"\"]+)\"\"\", RegexOptions.IgnoreCase)) urls.Add(m.Groups[1].Value);",
        "    foreach (Match m in Regex.Matches(source, @\"href\\s*=\\s*'([^']+)'\", RegexOptions.IgnoreCase)) urls.Add(m.Groups[1].Value);",
        "",
        "    if (urls.Count == 0)",
        "    {",
        "        foreach (Match m in Regex.Matches(source, @\"https?://\\S+\", RegexOptions.IgnoreCase)) urls.Add(m.Value);",
        "    }",
        "",
        "    urls = urls.Select(u => CleanUrl(u)).Where(u => Uri.IsWellFormedUriString(u, UriKind.Absolute)).Distinct().ToList();",
        "    if (urls.Count == 0) { context.Notify(\"No URLs found.\"); return; }",
        "",
        "    string downloadRoot = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.UserProfile), \"Downloads\");",
        "    string downloadDir = Path.Combine(downloadRoot, DateTime.Now.ToString(\"yyyyMMdd_HHmmss\"));",
        "    Directory.CreateDirectory(downloadDir);",
        "",
        "    using var client = new HttpClient();",
        "    foreach (var url in urls)",
        "    {",
        "        try",
        "        {",
        "            var uri = new Uri(url);",
        "            string fileName = Path.GetFileName(uri.LocalPath);",
        "            if (string.IsNullOrWhiteSpace(fileName)) fileName = \"download\";",
        "            fileName = SafeName(fileName);",
        "            string target = EnsureUniquePath(Path.Combine(downloadDir, fileName));",
        "            var bytes = await client.GetByteArrayAsync(uri);",
        "            await File.WriteAllBytesAsync(target, bytes);",
        "        }",
        "        catch (Exception ex)",
        "        {",
        "            Simpler.Core.Logging.Write($\"Download failed: {url}\\n{ex}\");",
        "        }",
        "    }",
        "    try { System.Diagnostics.Process.Start(\"explorer.exe\", downloadDir); } catch { }",
        "}",
        "",
        "string CleanUrl(string u)",
        "{",
        "    return u.Trim().TrimEnd(')', ']', '}', ',', ';', '\"');",
        "}",
        "",
        "string SafeName(string name)",
        "{",
        "    foreach (var c in Path.GetInvalidFileNameChars()) name = name.Replace(c, '_');",
        "    return name;",
        "}",
        "",
        "string EnsureUniquePath(string path)",
        "{",
        "    if (!File.Exists(path)) return path;",
        "    var dir = Path.GetDirectoryName(path) ?? \"\";",
        "    var baseName = Path.GetFileNameWithoutExtension(path);",
        "    var ext = Path.GetExtension(path);",
        "    for (int i = 1; i < 10000; i++)",
        "    {",
        "        var p = Path.Combine(dir, baseName + \"_\" + i + ext);",
        "        if (!File.Exists(p)) return p;",
        "    }",
        "    return path;",
        "}"
      ],
      "op": "csharp"
    }
  ]
}
